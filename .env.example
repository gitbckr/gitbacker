# Postgres
DATABASE_URL=postgresql+asyncpg://gitbacker:gitbacker@localhost:5432/gitbacker

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=changeme-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Host paths for persistent data
# DB_DIR: Postgres + Redis (keep on fast local storage)
# BACKUP_DIR: backup archives (point to large/external mount if needed)
DB_DIR=./data
BACKUP_DIR=./data/backups

# App
ENVIRONMENT=development
